<?xml version="1.0" encoding="utf-8"?>
<mdscript name="X4Native"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:noNamespaceSchemaLocation="md.xsd">
  <cues>

    <!-- Stage 2: Signal Lua once the game is fully loaded.
         Uses the engine's event_game_loaded which fires on every save load / new game.
         instantiate="true" allows it to fire on every load, not just the first. -->
    <cue name="x4native_GameLoaded" instantiate="true">
      <conditions>
        <check_any>
          <event_game_loaded />
          <event_game_started />
        </check_any>
      </conditions>
      <actions>
        <debug_text text="'X4Native: MD signalling game_loaded to Lua'" filter="general"/>
        <raise_lua_event name="'x4native.game_loaded'" />
      </actions>
    </cue>

    <!-- Stage 3: Signal Lua on every game save. -->
    <cue name="x4native_GameSaved" instantiate="true">
      <conditions>
        <event_game_saved />
      </conditions>
      <actions>
        <debug_text text="'X4Native: MD signalling game_saved to Lua'" filter="general"/>
        <raise_lua_event name="'x4native.game_saved'" />
      </actions>
    </cue>

  </cues>
</mdscript>
